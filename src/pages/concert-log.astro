const SHEET_CSV_URL="https://docs.google.com/spreadsheets/d/e/2PACX-1vSgzsdhJH86SZb6YnQc3SFagzx5sCp0tPu53w4OtfIhU-8fkrOuCjKcJVhVnlFl4oY-M5RbQniM9D_B/pub?output=csv";
const _MONS=['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
const _MONL=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
function deriveShow(s){const p=(s.date||'').split('-').map(Number),y=p[0],m=p[1],d=p[2];
  return {date:s.date,year:y,display:`${_MONL[m-1]} ${d}, ${y}`,mon:_MONS[m-1],day:String(d),
    venue:s.venue,city:s.city,state:s.state,tour:s.tour||'',type:s.type||'Concert',artists:s.artists,
    image:s.image||'',friends:s.friends||[],league:s.league||'',note:s.note||''};}
function parseCSV(text){const rows=[];let row=[],f='',i=0,q=false;text=text.replace(/\r\n?/g,'\n');
  while(i<text.length){const c=text[i];
    if(q){if(c==='"'){if(text[i+1]==='"'){f+='"';i+=2;continue;}q=false;i++;continue;}f+=c;i++;continue;}
    if(c==='"'){q=true;i++;continue;}
    if(c===','){row.push(f);f='';i++;continue;}
    if(c==='\n'){row.push(f);rows.push(row);row=[];f='';i++;continue;}
    f+=c;i++;}
  if(f.length||row.length){row.push(f);rows.push(row);}
  return rows;}
function rowsToShows(rows){if(!rows.length)return [];
  const head=rows[0].map(h=>h.trim().toLowerCase()),at=n=>head.indexOf(n);
  const di=at('date'),vi=at('venue'),ci=at('city'),si=at('state'),ti=at('tour'),pi=at('type'),ai=at('artists'),ii=at('image'),fri=at('friends'),li=at('league'),ni=at('note');
  const out=[];
  for(let r=1;r<rows.length;r++){const c=rows[r],date=(c[di]||'').trim();if(!date)continue;
    out.push(deriveShow({date,venue:(c[vi]||'').trim(),city:(c[ci]||'').trim(),state:(c[si]||'').trim().toUpperCase(),
      tour:(c[ti]||'').trim(),type:(c[pi]||'').trim()||'Concert',image:(c[ii]||'').trim(),
      artists:(c[ai]||'').split(';').map(x=>x.trim()).filter(Boolean),
      friends:(c[fri]||'').split(';').map(x=>x.trim()).filter(Boolean),
      league:(c[li]||'').trim(),note:(c[ni]||'').trim()}));}
  return out;}
const _SHOWS_CACHE_KEY='cl_shows_v1', _SHOWS_CACHE_TTL=30*24*3600*1000;
async function loadShows(){
  if(!SHEET_CSV_URL)return null;
  try{
    const res=await fetch(SHEET_CSV_URL,{cache:'no-store'});
    if(!res.ok)throw new Error('HTTP '+res.status);
    const shows=rowsToShows(parseCSV(await res.text()));
    if(shows&&shows.length){try{localStorage.setItem(_SHOWS_CACHE_KEY,JSON.stringify({t:Date.now(),shows}));}catch(_){}}
    return shows;
  }catch(e){
    // Sheet unreachable — try the most recent good load from localStorage before falling through.
    try{const cached=JSON.parse(localStorage.getItem(_SHOWS_CACHE_KEY)||'null');
      if(cached&&cached.shows&&cached.shows.length&&(Date.now()-cached.t)<_SHOWS_CACHE_TTL){
        console.warn('Concert sheet unreachable; using cached shows from',new Date(cached.t).toISOString());
        return cached.shows;
      }
    }catch(_){}
    throw e;
  }
}

/* ---- AUTO ARTIST IMAGES (Wikipedia, cached in localStorage) ----
   On first load we look up each artist's Wikipedia thumbnail and stash the URL.
   Cached 30 days per artist so subsequent loads are instant. The sheet's image
   column overrides the auto pick for the row's headliner. Hints handle the few
   common-noun bands where bare search lands on the wrong page. */
const _IMG_KEY='cl_artistImg_v2',_IMG_TTL=30*24*3600*1000,_IMG_MISS_TTL=3*24*3600*1000;
const _IMG_HINTS={
  // Music — ambiguous artist names that Wikipedia bare-search gets wrong
  'Goose':'Goose (American band)','Ghost':'Ghost (Swedish band)','Spoon':'Spoon (band)',
  'Slipknot':'Slipknot (band)','Drake':'Drake (musician)','Disturbed':'Disturbed (band)',
  'P!nk':'Pink (singer)','Disclosure':'Disclosure (band)','Flume':'Flume (musician)',
  'Bleachers':'Bleachers (band)','B.o.B':'B.o.B (rapper)',
  'Empire of the Sun':'Empire of the Sun (band)','Mk.Gee':'Mk.gee',
  'ZHU':'Zhu (musician)',
  // Football — NCAAF teams resolve to "<team> football" articles which carry the logo.
  // NFL teams use their direct article. A few NCAAF teams need name normalization first.
  'Alabama Crimson Tide':'Alabama Crimson Tide football','Arkansas Razorbacks':'Arkansas Razorbacks football',
  'BYU Cougars':'BYU Cougars football','Baylor Bears':'Baylor Bears football',
  'California Bears':'California Golden Bears football','Central Arkansas Bears':'Central Arkansas Bears football',
  'Charleston Southern Buccaneers':'Charleston Southern Buccaneers football','Clemson Tigers':'Clemson Tigers football',
  'Colorado Buffaloes':'Colorado Buffaloes football','Colorado State Rams':'Colorado State Rams football',
  'Florida Gators':'Florida Gators football','Georgia Bulldogs':'Georgia Bulldogs football',
  "Hawai'i Rainbow Warriors":'Hawaii Rainbow Warriors football','Houston Cougars':'Houston Cougars football',
  'Indiana Hoosiers':'Indiana Hoosiers football','Iowa State Cyclones':'Iowa State Cyclones football',
  'Kansas Jayhawks':'Kansas Jayhawks football','Kansas State Wildcats':'Kansas State Wildcats football',
  'Kentucky Wildcats':'Kentucky Wildcats football','LA-Monroe Warhawks':'Louisiana–Monroe Warhawks football',
  'LSU Tigers':'LSU Tigers football','Michigan Wolverines':'Michigan Wolverines football',
  'Notre Dame Fighting Irish':'Notre Dame Fighting Irish football','Ohio State Buckeyes':'Ohio State Buckeyes football',
  'Oklahoma Sooners':'Oklahoma Sooners football','Oklahoma State Cowboys':'Oklahoma State Cowboys football',
  'Oregon Ducks':'Oregon Ducks football','Rice Owls':'Rice Owls football',
  'SMU Mustangs':'SMU Mustangs football','Sam Houston State Bearkats':'Sam Houston Bearkats football',
  'TCU Horned Frogs':'TCU Horned Frogs football','Texas A&M Aggies':'Texas A&M Aggies football',
  'Texas Longhorns':'Texas Longhorns football','USC Trojans':'USC Trojans football',
  'UTEP Miners':'UTEP Miners football','UTSA Road Runners':'UTSA Roadrunners football',
  'Utah Utes':'Utah Utes football','Vanderbilt Commodores':'Vanderbilt Commodores football',
  'Washington Huskies':'Washington Huskies football','West Virginia Mountaineers':'West Virginia Mountaineers football',
  'Wyoming Cowboys':'Wyoming Cowboys football',
  // NFL — Oakland Raiders moved/renamed; the rest are direct article hits.
  'Oakland Raiders':'Las Vegas Raiders'};
let artistImg={};
function _loadImgCache(){try{const j=JSON.parse(localStorage.getItem(_IMG_KEY)||'{}'),now=Date.now(),out={};
  for(const k in j){const e=j[k];if(!e)continue;const ttl=e.url?_IMG_TTL:_IMG_MISS_TTL;
    if(now-e.t<ttl)out[k]=e;} return out;}catch(e){return {};}}
function _saveImgCache(c){try{localStorage.setItem(_IMG_KEY,JSON.stringify(c));}catch(e){}}
async function _wikiThumb(q){
  const url='https://en.wikipedia.org/w/api.php?'+new URLSearchParams({
    action:'query',format:'json',origin:'*',generator:'search',gsrsearch:q,gsrlimit:'1',
    prop:'pageimages',piprop:'thumbnail',pithumbsize:'120',formatversion:'2'});
  try{const r=await fetch(url);if(!r.ok)return null;
    const j=await r.json(),p=j.query&&j.query.pages&&j.query.pages[0];
    return (p&&p.thumbnail&&p.thumbnail.source)||null;}catch(e){return null;}}
async function _wikiSummaryThumb(title){
  // REST summary endpoint exposes the article's lead image (often the logo) even when
  // the legacy pageimages API doesn't tag it. Great for NFL teams.
  const url='https://en.wikipedia.org/api/rest_v1/page/summary/'+encodeURIComponent(title.replace(/ /g,'_'));
  try{const r=await fetch(url);if(!r.ok)return null;
    const j=await r.json();
    return (j.thumbnail&&j.thumbnail.source)||null;}catch(e){return null;}}
async function _wikiBatch(titles){
  // Look up many titles at once (up to 50), following redirects/normalizations.
  // Returns { inputTitle: thumbnailUrl } only for titles whose article had a pageimage.
  const url='https://en.wikipedia.org/w/api.php?'+new URLSearchParams({
    action:'query',format:'json',origin:'*',redirects:'1',
    titles:titles.join('|'),prop:'pageimages',piprop:'thumbnail',pithumbsize:'120',formatversion:'2'});
  try{const r=await fetch(url);if(!r.ok)return {};
    const j=await r.json(),q=j.query||{},fwd={};
    titles.forEach(t=>fwd[t]=t);
    (q.normalized||[]).forEach(n=>{for(const k in fwd) if(fwd[k]===n.from)fwd[k]=n.to;});
    (q.redirects||[]).forEach(rr=>{for(const k in fwd) if(fwd[k]===rr.from)fwd[k]=rr.to;});
    const thumb={};
    (q.pages||[]).forEach(p=>{if(p.thumbnail&&p.thumbnail.source)thumb[p.title]=p.thumbnail.source;});
    const out={};
    titles.forEach(t=>{if(thumb[fwd[t]])out[t]=thumb[fwd[t]];});
    return out;}catch(e){return {};}}
function _initArtistImages(){
  const ov={}; DATA.forEach(s=>{if(s.image&&s.artists[0])ov[s.artists[0]]=s.image;});
  const cache=_loadImgCache(); artistImg={};
  const all=[...new Set(DATA.flatMap(s=>s.artists))], need=[];
  all.forEach(n=>{
    if(ov[n])artistImg[n]=ov[n];
    else if(n in cache){if(cache[n].url)artistImg[n]=cache[n].url;}
    else need.push(n);});
  return {cache,need};}
function applyAvatar(name,url){
  document.querySelectorAll('[data-artist]').forEach(el=>{
    if(el.getAttribute('data-artist')!==name)return;
    if(el.querySelector('.who-avatar,.artcard-avatar'))return;
    const cls=el.classList.contains('who-act')?'who-avatar':'artcard-avatar';
    const img=document.createElement('img'); img.className=cls; img.src=url; img.alt=''; img.loading='lazy';
    img.onerror=()=>img.remove();
    el.prepend(img);});}
async function _backgroundFetchImages(cache,need){
  // Phase A: batched direct-title lookups. Each artist's hint (if any) becomes its query title.
  const queryToArtist={}; const queries=need.map(n=>{const q=_IMG_HINTS[n]||n; queryToArtist[q]=n; return q;});
  for(let i=0;i<queries.length;i+=50){
    const batch=queries.slice(i,i+50);
    const res=await _wikiBatch(batch);
    for(const q in res){const n=queryToArtist[q], url=res[q];
      cache[n]={url,t:Date.now()}; artistImg[n]=url; applyAvatar(n,url);}
    _saveImgCache(cache);
    await new Promise(r=>setTimeout(r,300));
  }
  // Phase B: per-artist fallback for stragglers. Try the REST summary endpoint first
  // (catches articles like NFL teams where pageimages has no thumbnail but the lead
  // image is the logo), then a search-based last resort with " band" suffix for music
  // disambiguation. Throttle to stay under Wikipedia's rate cap.
  const stragglers=need.filter(n=>!cache[n]);
  for(const n of stragglers){
    let url=await _wikiSummaryThumb(_IMG_HINTS[n]||n);
    if(!url) url=await _wikiThumb(n+' band');
    if(!url) url=await _wikiThumb(n);
    cache[n]={url:url||null,t:Date.now()};
    if(url){artistImg[n]=url; applyAvatar(n,url);}
    _saveImgCache(cache);
    await new Promise(r=>setTimeout(r,1500));
  }
}

let order="desc",view="timeline",artSort="count";
const filt={cat:"music",q:"",state:"ALL",type:"ALL"};
let repeatMap={},yrsAll=[];

/* ---- CATEGORIES ----
   The site shows three event types backed by the same sheet. The 'type' column
   in the sheet drives which tab a row belongs to: Concert/Festival → Music,
   Stand-Up → Stand-Up, Football → Football. Each tab swaps the hero copy and
   filters the timeline/map/stats below. Deep-link with #music / #standup /
   #football in the URL. */
const CATS={
  music:{types:['Concert','Festival'],
    title:'Live',
    kicker:y=>`Concerts I've been to · ${y}`,
    sub:'Every show, every stage. From Colorado mountainsides to Austin festival fields. Search it, map it, relive it.',
    docTitle:'Live: A Concert Log',
    spanLabel:'Concerts across the span',
    buddiesLabel:'Concert buddies'},
  standup:{types:['Stand-Up'],
    title:'Live',
    kicker:y=>`Stand-up shows I've been to · ${y}`,
    sub:"Every set, every laugh. The comedians I've caught in person — from clubs to arenas.",
    docTitle:'Live: A Stand-Up Log',
    spanLabel:'Sets across the span',
    buddiesLabel:'Comedy buddies'},
  football:{types:['Football'],
    title:'Live',
    kicker:y=>`Football games I've been to · ${y}`,
    sub:"Every kickoff, every stadium. The football games I've watched in person.",
    docTitle:'Live: A Football Log',
    spanLabel:'Games across the span',
    buddiesLabel:'Football buddies'},
};
function _validCat(c){return CATS[c]?c:'music';}
function _catFromHash(){return _validCat((location.hash||'').slice(1).toLowerCase());}
function inCat(s,cat){return CATS[cat].types.indexOf(s.type)!==-1;}

function _nounFor(cat){return cat==='music'?'shows':cat==='standup'?'sets':'games';}
function _singularNounFor(cat){return cat==='music'?'show':cat==='standup'?'set':'game';}
function _noun(cat,n){const s=_singularNounFor(cat);return n===1?s:s+'s';}
function _actorLabelFor(cat){return cat==='music'?'Artists':cat==='standup'?'Comedians':'Teams';}
function _showsLabelFor(cat){return cat==='music'?'Shows':cat==='standup'?'Sets':'Games';}

function boot(){
  filt.cat=_catFromHash();
  // Per-cat counts on the catbar (computed once from full DATA)
  for(const c in CATS){const n=DATA.filter(s=>inCat(s,c)).length;
    const el=document.querySelector(`.catbtn .ct[data-ct="${c}"]`); if(el)el.textContent=n?'· '+n:'';}
  // Wire catbar — clicking sets the hash, hashchange triggers re-render
  document.querySelectorAll('.catbtn').forEach(b=>b.onclick=()=>{location.hash='#'+b.dataset.cat;});
  window.addEventListener('hashchange',()=>{filt.cat=_catFromHash();applyCat();});
  // Type chips are static (only meaningful in Music); wire once
  document.getElementById('typeChips').innerHTML=`<button class="chip on" data-ty="ALL">All</button>
    <button class="chip" data-ty="Festival">Festivals</button><button class="chip" data-ty="Concert">Concerts</button>`;
  document.querySelectorAll('#typeChips .chip').forEach(c=>c.onclick=()=>{filt.type=c.dataset.ty;
    document.querySelectorAll('#typeChips .chip').forEach(x=>x.classList.toggle('on',x===c));refresh();});
  // Populate artistImg from localStorage cache + sheet overrides BEFORE the first
  // render so cached avatars appear inline in cards immediately; new entries pop in
  // later via applyAvatar() as the background fetch resolves them.
  const imgs=_initArtistImages();
  applyCat();
  if(imgs.need.length)_backgroundFetchImages(imgs.cache,imgs.need);
}

function applyCat(){
  const cfg=CATS[filt.cat];
  document.querySelectorAll('.catbtn').forEach(b=>b.classList.toggle('on',b.dataset.cat===filt.cat));
  document.title=cfg.docTitle;
  // Subset of DATA in current category
  const sub=DATA.filter(s=>inCat(s,filt.cat));
  const allActs=[...new Set(sub.flatMap(s=>s.artists))];
  document.getElementById('mq').innerHTML=allActs.length?(allActs.join('  <b>✦</b>  ')+'  <b>✦</b>  ').repeat(2):'';
  const uShows=sub.length, uArtists=allActs.length,
    uVenues=new Set(sub.map(s=>s.venue)).size, uStates=new Set(sub.map(s=>s.state)).size;
  yrsAll=sub.map(s=>s.year);
  const minY=yrsAll.length?Math.min(...yrsAll):0, maxY=yrsAll.length?Math.max(...yrsAll):0, span=Math.max(0,maxY-minY);
  // Hero copy
  document.querySelector('.kicker').textContent=cfg.kicker(yrsAll.length?`${minY} – ${maxY}`:'coming soon');
  document.querySelector('.hero .sub').textContent=cfg.sub;
  const legend=document.getElementById('legendNote');
  if(legend)legend.textContent=`○ marker size = ${_nounFor(filt.cat)} seen there · click for details`;
  // Stats strip
  const actor=_actorLabelFor(filt.cat);
  document.getElementById('statstrip').innerHTML=
    [[_showsLabelFor(filt.cat),uShows],[actor,uArtists],["Venues",uVenues],["States",uStates],["Years",span]]
    .map(([l,n])=>`<div class="stat"><div class="n" data-to="${n}">0</div><div class="l">${l}</div></div>`).join('');
  countUp();
  // Repeat map (used by card() to show ×N) — scoped to category
  repeatMap={}; sub.flatMap(s=>s.artists).forEach(a=>repeatMap[a]=(repeatMap[a]||0)+1);
  // State chips: only states this category covers; reset state filter on cat switch
  filt.state='ALL';
  const states=[...new Set(sub.map(s=>s.state))];
  document.getElementById('stateChips').innerHTML=`<button class="chip on" data-st="ALL">All</button>`+
    states.map(s=>`<button class="chip dot" data-st="${s}" style="color:${STCOL[s]||'#e9b14a'}">${s}</button>`).join('');
  document.querySelectorAll('#stateChips .chip').forEach(c=>c.onclick=()=>{filt.state=c.dataset.st;
    document.querySelectorAll('#stateChips .chip').forEach(x=>x.classList.toggle('on',x===c));refresh();});
  // Concert/Festival chips only meaningful in Music
  document.getElementById('typeChips').style.display=filt.cat==='music'?'':'none';
  if(filt.cat!=='music'){filt.type='ALL';
    document.querySelectorAll('#typeChips .chip').forEach(x=>x.classList.toggle('on',x.dataset.ty==='ALL'));}
  // Footer
  const noun=_nounFor(filt.cat);
  document.getElementById('foot').innerHTML = uShows
    ? `${uShows} ${noun} · ${uArtists} ${actor.toLowerCase()} · ${uVenues} venues · ${minY}–${maxY}. ✦`
    : `No ${noun} yet — add rows with type "${cfg.types.join(' / ')}" to the sheet.`;
  refresh();
}
function countUp(){document.querySelectorAll('.stat .n').forEach(el=>{const to=+el.dataset.to;let c=0;const st=Math.max(1,Math.round(to/40));
  const t=setInterval(()=>{c+=st;if(c>=to){c=to;clearInterval(t)}el.textContent=c;},22);});}
document.getElementById('q').oninput=e=>{filt.q=e.target.value.toLowerCase();refresh();};
document.getElementById('orderBtn').onclick=function(){order=order==="desc"?"asc":"desc";
  this.textContent=order==="desc"?"▼ Newest":"▲ Oldest";renderTimeline();};
document.querySelectorAll('.tab').forEach(t=>t.onclick=()=>setView(t.dataset.view));

function setView(v){view=v;
  document.querySelectorAll('.tab').forEach(t=>t.classList.toggle('on',t.dataset.view===v));
  document.getElementById('timeline').style.display=v==="timeline"?"block":"none";
  document.getElementById('mapview').classList.toggle('show',v==="map");
  document.getElementById('statsview').classList.toggle('show',v==="stats");
  document.getElementById('orderBtn').style.visibility=v==="timeline"?"visible":"hidden";
  if(v==="map")renderMap();
  if(v==="stats")buildStats();
}
function match(s){
  if(!inCat(s,filt.cat))return false;
  if(filt.state!=="ALL"&&s.state!==filt.state)return false;
  if(filt.cat==="music"&&filt.type!=="ALL"&&s.type!==filt.type)return false;
  if(filt.q){const h=(s.venue+' '+s.city+' '+s.state+' '+s.tour+' '+s.artists.join(' ')+' '+(s.friends||[]).join(' ')).toLowerCase();
    if(!h.includes(filt.q))return false;}
  return true;
}
function filtered(){return DATA.filter(match);}
function refresh(){renderTimeline(); if(view==="map")renderMap(); if(view==="stats")buildStats();}

function renderTimeline(){
  const rows=filtered().slice().sort((a,b)=>order==="desc"?b.date.localeCompare(a.date):a.date.localeCompare(b.date));
  const nA=new Set(rows.flatMap(s=>s.artists)).size;
  document.getElementById('countline').innerHTML=`Showing <b>${rows.length}</b> ${_noun(filt.cat,rows.length)} · <b>${nA}</b> ${_actorLabelFor(filt.cat).toLowerCase()}`;
  const tl=document.getElementById('timeline');
  if(!rows.length){
    const noun=_nounFor(filt.cat), totalInCat=DATA.filter(s=>inCat(s,filt.cat)).length;
    tl.innerHTML=totalInCat
      ? `<div class="empty">No ${noun} match that. Try clearing the search (Esc).</div>`
      : `<div class="empty">No ${noun} logged yet.<br><span style="opacity:.6">Add rows with type "${CATS[filt.cat].types.join(' / ')}" to your sheet to populate this tab.</span></div>`;
    return;}
  const byYear={}; rows.forEach(s=>{(byYear[s.year]=byYear[s.year]||[]).push(s);});
  const years=Object.keys(byYear).sort((a,b)=>order==="desc"?b-a:a-b);
  tl.innerHTML=years.map(y=>{const ss=byYear[y];
    return `<div class="year-block"><div class="year-head"><div class="y">${y}</div><div class="bar"></div><div class="ct">${ss.length} ${_noun(filt.cat,ss.length)}</div></div>`+
      ss.map(card).join('')+`</div>`;}).join('');
  observe();
}
function avatarHtml(name,cls){const u=artistImg[name];if(!u)return '';
  return `<img class="${cls}" src="${u.replace(/"/g,'&quot;')}" alt="" loading="lazy" onerror="this.remove()">`;}
function slugify(s){return (s||'').toLowerCase().replace(/['']/g,'').replace(/[^a-z0-9]+/g,'-').replace(/^-+|-+$/g,'');}
function _venueLogoFallback(img){const tries=['webp','svg','jpg'];img.__t=img.__t||0;
  if(img.__t<tries.length){img.src=img.src.replace(/\.[a-z]+$/i,'.'+tries[img.__t++]);}else{img.remove();}}
function venueLogoHtml(venue){return `<img class="venue-logo" src="/venues/${slugify(venue)}.png" alt="" loading="lazy" onerror="_venueLogoFallback(this)">`;}
function leagueLogoHtml(league){return `<img src="/leagues/${slugify(league)}.png" alt="" loading="lazy" onerror="_venueLogoFallback(this)">`;}
function noteLogoHtml(note){return `<img class="note-logo" src="/bowls/${slugify(note)}.png" alt="" loading="lazy" onerror="this.parentElement.classList.add('no-logo');this.remove();">`;}
function _initials(name){return (name||'').split(/\s+/).filter(Boolean).map(w=>w[0]||'').join('').slice(0,2).toUpperCase();}
function _colorFor(name){let h=0;for(let i=0;i<(name||'').length;i++)h=((h<<5)-h+name.charCodeAt(i))|0;
  return `hsl(${Math.abs(h)%360},42%,38%)`;}
function _personPhotoFallback(img){const tries=['png','webp'];img.__t=img.__t||0;
  if(img.__t<tries.length){img.src=img.src.replace(/\.[a-z]+$/i,'.'+tries[img.__t++]);}else{img.remove();}}
function personAvatarHtml(name,extraCls){
  const slug=slugify(name),initials=_initials(name),bg=_colorFor(name);
  return `<span class="person-av${extraCls?' '+extraCls:''}" style="background:${bg}">${initials}<img src="/people/${slug}.jpg" alt="" loading="lazy" onerror="_personPhotoFallback(this)"></span>`;}
function card(s){
  const who=s.artists.map(a=>`<span class="who-act" data-artist="${a.replace(/"/g,'&quot;')}" onclick="pickArtist('${a.replace(/'/g,"\\'")}')">${avatarHtml(a,'who-avatar')}${a}${repeatMap[a]>1?`<span class="x">×${repeatMap[a]}</span>`:''}</span>`).join('');
  const fr=s.friends||[];
  const withRow=fr.length?`<div class="with"><span class="with-label">With</span>${fr.map(f=>`<span class="friend" data-friend="${f.replace(/"/g,'&quot;')}" onclick="pickArtist('${f.replace(/'/g,"\\'")}')">${personAvatarHtml(f)}<span>${f}</span></span>`).join('')}</div>`:'';
  // For football rows with a league set, the league badge replaces the type tag.
  const tag = (s.type==='Football' && s.league)
    ? `<span class="tag-league">${leagueLogoHtml(s.league)}${s.league}</span>`
    : `<span class="tag ${s.type}">${s.type}</span>`;
  const noteRow = s.note
    ? `<div class="note">${noteLogoHtml(s.note)}<span>${s.note}</span></div>`
    : '';
  return `<div class="card s-${s.state}"><div class="date-blk"><div class="mon">${s.mon}</div><div class="day">${s.day}</div></div>
    <div><div class="top"><div class="who">${who}</div>
    ${tag}</div>
    <div class="where">${venueLogoHtml(s.venue)}${s.venue}</div>
    <div class="meta">${s.city}, <span class="st">${s.state}</span> · ${s.display}</div>
    ${s.tour?`<div class="tour">${s.tour}</div>`:''}${noteRow}${withRow}</div></div>`;
}
function pickArtist(name){filt.q=name.toLowerCase();document.getElementById('q').value=name;
  document.querySelectorAll('#stateChips .chip').forEach(x=>x.classList.toggle('on',x.dataset.st==="ALL"));
  document.querySelectorAll('#typeChips .chip').forEach(x=>x.classList.toggle('on',x.dataset.ty==="ALL"));
  filt.state="ALL";filt.type="ALL";setView('timeline');renderTimeline();window.scrollTo({top:document.querySelector('.controls').offsetTop,behavior:'smooth'});}
function observe(){/* entry animation removed — cards render in place */}

/* ---- MAP ---- */
let map,markerLayer;
function renderMap(){
  if(typeof L==="undefined"){setTimeout(renderMap,200);return;}
  if(!map){
    map=L.map('map',{scrollWheelZoom:false,attributionControl:true}).setView([35.5,-100],4);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',
      {attribution:'© OpenStreetMap, © CARTO',subdomains:'abcd',maxZoom:19}).addTo(map);
    markerLayer=L.layerGroup().addTo(map);
  }
  markerLayer.clearLayers();
  const rows=filtered();
  const agg={};
  rows.forEach(s=>{const v=agg[s.venue]=agg[s.venue]||{n:0,state:s.state,city:s.city,shows:[]};v.n++;v.shows.push(s);});
  const pts=[];
  Object.entries(agg).forEach(([name,v])=>{
    const c=VENUES[name]; if(!c){console.warn('No map coordinates for venue:',name,'— add it to the VENUES map to give it a pin.');return;} pts.push(c);
    const r=6+Math.sqrt(v.n)*4.2;
    const m=L.circleMarker(c,{radius:r,color:'#fff',weight:1,opacity:.6,fillColor:STCOL[v.state]||'#e9b14a',fillOpacity:.78});
    m.bindTooltip(`${name} · ${v.n}`,{direction:'top',className:'lf-tt'});
    const list=v.shows.slice().sort((a,b)=>b.date.localeCompare(a.date)).map(s=>
      `<div class="pp-s"><b>${s.display}</b>${s.artists.join(', ')}</div>`).join('');
    m.bindPopup(`<div class="pp-v">${name}</div><div class="pp-m">${v.city}, ${v.state} · ${v.n} ${_noun(filt.cat,v.n).toUpperCase()}</div>${list}`,{maxWidth:300});
    markerLayer.addLayer(m);
  });
  setTimeout(()=>{map.invalidateSize(); if(pts.length){map.fitBounds(pts,{padding:[50,50],maxZoom:7});}},80);
}

/* ---- STATS ---- */
function buildStats(){
  const rows=filtered();
  if(!yrsAll.length){document.getElementById('statsview').innerHTML='<div class="empty">No data yet for this category.</div>';return;}
  const minY=Math.min(...yrsAll),maxY=Math.max(...yrsAll);
  const yr={}; for(let y=minY;y<=maxY;y++)yr[y]=0;
  rows.forEach(s=>yr[s.year]++);
  const mx=Math.max(1,...Object.values(yr));
  const cols=Object.keys(yr).map(y=>`<div class="col ${yr[y]===0?'zero':''}"><div class="cnt">${yr[y]}</div><div class="bar" data-h="${yr[y]/mx*100}"></div><div class="yr">'${String(y).slice(2)}</div></div>`).join('');
  const ven={}; rows.forEach(s=>{const v=ven[s.venue]=ven[s.venue]||{n:0,st:s.state};v.n++;});
  const topV=Object.entries(ven).sort((a,b)=>b[1].n-a[1].n).slice(0,8)
    .map(([v,o])=>`<div class="vrow"><div class="nm">${v}</div><div class="ct">${o.n} ${_noun(filt.cat,o.n)}</div></div>`).join('');
  const stc={}; rows.forEach(s=>stc[s.state]=(stc[s.state]||0)+1);
  const stmx=Math.max(1,...Object.values(stc));
  const stBars=Object.entries(stc).sort((a,b)=>b[1]-a[1]).map(([s,n])=>
    `<div class="barrow"><div class="lab">${s}</div><div class="track"><div class="fill" data-w="${n/stmx*100}" style="background:${STCOL[s]}"></div></div><div class="v">${n}</div></div>`).join('');
  // artists from filtered rows
  const am={}; rows.forEach(s=>s.artists.forEach(a=>{const o=am[a]=am[a]||{n:0,ys:new Set()};o.n++;o.ys.add(s.year);}));
  let arts=Object.entries(am).map(([a,o])=>({a,n:o.n,min:Math.min(...o.ys),max:Math.max(...o.ys)}));
  if(artSort==="count")arts.sort((x,y)=>y.n-x.n||x.a.localeCompare(y.a));
  else if(artSort==="az")arts.sort((x,y)=>x.a.localeCompare(y.a));
  else arts.sort((x,y)=>y.max-x.max||y.n-x.n);
  const artHtml=arts.map(o=>`<div class="artcard" data-artist="${o.a.replace(/"/g,'&quot;')}" onclick="pickArtist('${o.a.replace(/'/g,"\\'")}')">
    ${avatarHtml(o.a,'artcard-avatar')}<div><div class="an">${o.a}</div><div class="ay">${o.min===o.max?o.min:o.min+'–'+o.max}</div></div>
    <div class="ac">${o.n>1?'×'+o.n:'•'}</div></div>`).join('');
  // friends/buddies from filtered rows
  const fm={}; rows.forEach(s=>(s.friends||[]).forEach(f=>{const o=fm[f]=fm[f]||{n:0,ys:new Set()};o.n++;o.ys.add(s.year);}));
  const buds=Object.entries(fm).map(([f,o])=>({f,n:o.n,min:Math.min(...o.ys),max:Math.max(...o.ys)}))
    .sort((a,b)=>b.n-a.n||a.f.localeCompare(b.f));
  const budHtml=buds.map(o=>`<div class="artcard" data-friend="${o.f.replace(/"/g,'&quot;')}" onclick="pickArtist('${o.f.replace(/'/g,"\\'")}')">
    ${personAvatarHtml(o.f,'lg')}<div><div class="an">${o.f}</div><div class="ay">${o.min===o.max?o.min:o.min+'–'+o.max}</div></div>
    <div class="ac">${o.n>1?'×'+o.n:'•'}</div></div>`).join('');
  const sb=(k,l)=>`<button class="tab ${artSort===k?'on':''}" onclick="artSort='${k}';buildStats()">${l}</button>`;
  const cfg=CATS[filt.cat], actor=_actorLabelFor(filt.cat);
  document.getElementById('statsview').innerHTML=`
    <div class="panel"><h3>${cfg.spanLabel} · ${minY}–${maxY}</h3><div class="spanchart">${cols}</div></div>
    <div class="panel"><h3>By state</h3>${stBars}</div>
    <div class="panel"><h3>Most-visited venues</h3>${topV}</div>
    ${buds.length?`<div class="panel"><h3>${cfg.buddiesLabel} · ${buds.length}</h3><div class="artgrid">${budHtml}</div></div>`:''}
    <div class="panel"><h3><span>${actor} · ${arts.length}</span><span class="sortbtns">${sb('count','Most seen')}${sb('recent','Recent')}${sb('az','A–Z')}</span></h3><div class="artgrid">${artHtml}</div></div>`;
  requestAnimationFrame(()=>setTimeout(()=>{
    document.querySelectorAll('.spanchart .bar').forEach(b=>b.style.height=b.dataset.h+'%');
    document.querySelectorAll('.barrow .fill').forEach(f=>f.style.width=f.dataset.w+'%');
  },60));
}
document.addEventListener('keydown',e=>{if(e.key==='Escape'){document.getElementById('q').value='';filt.q='';refresh();}});
(async()=>{
  document.getElementById('timeline').innerHTML='<div class="empty">Loading shows…</div>';
  try{
    const rows=await loadShows();
    if(rows&&rows.length)DATA=rows;
    else if(rows)console.warn('Concert sheet loaded but had no rows; using built-in list.');
  }catch(e){console.warn('Concert sheet load failed; using built-in list.',e);}
  boot();
})();
</script>
</body>
</html>