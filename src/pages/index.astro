<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Julian John Fife</title>
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='8' fill='%23f8e4c9'/%3E%3Ctext x='32' y='43' font-family='monospace' font-weight='700' font-size='28' fill='%23000000' text-anchor='middle'%3EJF%3C/text%3E%3C/svg%3E">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Source+Code+Pro:wght@400;500;600;700&display=swap" rel="stylesheet">
  <style is:global>
    :root {
      --bg: #f8e4c9;
      --ink: #1a1410;
      --muted: rgba(26, 20, 16, 0.62);
      --line: rgba(26, 20, 16, 0.14);
      --line-soft: rgba(26, 20, 16, 0.08);
      --card: rgba(255, 255, 255, 0.28);
      --accent: #b5491b;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      background-color: var(--bg);
      color: var(--ink);
      font-family: 'Source Code Pro', monospace;
      font-size: 16px;
      line-height: 1.65;
      padding: 72px 24px 96px;
      -webkit-font-smoothing: antialiased;
    }
    .container { max-width: 760px; margin: 0 auto; }

    a { color: var(--ink); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ---- Header ---- */
    .header { display: flex; align-items: center; gap: 22px; margin-bottom: 10px; }
    .profile-photo {
      width: 84px; height: 84px; min-width: 84px; border-radius: 50%;
      object-fit: cover; border: 2px solid rgba(255,255,255,0.5);
      box-shadow: 0 6px 20px rgba(26,20,16,0.14);
    }
    h1 { font-size: 2.05rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.5px; }
    .tagline { font-size: 0.95rem; color: var(--muted); margin: 6px 0 0; }
    .tagline-chips { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 10px; }
    .chip {
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.04em;
      padding: 3px 10px; border: 1px solid var(--line); border-radius: 999px;
      color: var(--muted); background: var(--card);
    }

    /* ---- Stats strip ---- */
    .stats {
      display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px;
      margin: 30px 0 40px;
    }
    .stat {
      border: 1px solid var(--line); border-radius: 12px; padding: 14px 12px;
      background: var(--card); text-align: center;
      transition: transform 0.18s, border-color 0.18s, background 0.18s;
    }
    a.stat:hover { text-decoration: none; transform: translateY(-3px); border-color: var(--accent); background: rgba(255,255,255,0.45); }
    .stat .num { display: block; font-size: 1.7rem; font-weight: 700; line-height: 1; letter-spacing: -1px; }
    .stat .lbl { display: block; margin-top: 7px; font-size: 0.66rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: var(--muted); }

    /* ---- Sections ---- */
    .section { margin-bottom: 44px; }
    .section-label {
      font-weight: 700; font-size: 0.74rem; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--accent); margin-bottom: 16px;
      display: flex; align-items: center; gap: 12px;
    }
    .section-label::after { content: ""; flex: 1; height: 1px; background: var(--line-soft); }

    .list { list-style: none; }
    .list li { padding: 9px 0; border-bottom: 1px solid var(--line-soft); display: flex; gap: 12px; align-items: baseline; }
    .list li:last-child { border-bottom: none; }
    .list .year { font-size: 0.8rem; color: var(--muted); min-width: 3.2em; font-weight: 600; }
    .list .lead::before { content: ""; }
    .restaurant-list a { transition: padding-left 0.18s; }
    .restaurant-list a:hover { padding-left: 6px; }
    .restaurant-list a:hover::before { content: '\2192\00a0'; color: var(--accent); }

    .subscribe-link { display: inline-flex; align-items: center; gap: 6px; margin-top: 14px; font-size: 0.85rem; color: var(--muted); transition: color 0.18s; }
    .subscribe-link:hover { color: var(--accent); }
    .subscribe-link img { height: 1em; }

    .longhorns-logo, .inline-flag { height: 1em; vertical-align: middle; margin-left: 4px; }

    /* hover pic (bio) */
    .hover-pic { position: relative; cursor: pointer; border-bottom: 1px dotted var(--muted); }
    .hover-pic .hover-tooltip {
      display: none; position: absolute; bottom: calc(100% + 8px); left: 50%;
      transform: translateX(-50%); width: 120px; height: 120px; border-radius: 12px;
      overflow: hidden; box-shadow: 0 10px 28px rgba(26,20,16,0.28); z-index: 10; pointer-events: none;
    }
    .hover-pic .hover-tooltip img { width: 100%; height: 100%; object-fit: cover; }
    .hover-pic:hover .hover-tooltip { display: block; }

    /* ---- Connect ---- */
    .social-group { margin-bottom: 18px; }
    .social-group:last-child { margin-bottom: 0; }
    .social-group-label { font-size: 0.78rem; color: var(--muted); margin-bottom: 8px; }
    .social-icons { display: flex; flex-wrap: wrap; gap: 18px; align-items: center; }
    .social-icons a { display: inline-block; width: 26px; height: 26px; opacity: 0.8; transition: opacity 0.18s, transform 0.18s; }
    .social-icons a:hover { opacity: 1; transform: translateY(-2px); text-decoration: none; }
    .social-icons a svg { width: 100%; height: 100%; fill: var(--ink); }

    /* ---- Big link cards ---- */
    .cards { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    .big-link {
      display: block; border: 1px solid var(--line); border-radius: 14px; padding: 20px;
      background: var(--card); transition: background 0.18s, transform 0.18s, border-color 0.18s, box-shadow 0.18s;
    }
    .big-link:hover { text-decoration: none; transform: translateY(-3px); border-color: var(--accent); box-shadow: 0 12px 30px rgba(26,20,16,0.12); background: rgba(255,255,255,0.45); }
    .big-link .title { display: block; font-weight: 700; font-size: 1.02rem; }
    .big-link .title .arrow { transition: margin-left 0.18s; display: inline-block; }
    .big-link:hover .title .arrow { margin-left: 6px; }
    .big-link .sub { display: block; font-size: 0.82rem; color: var(--muted); margin-top: 6px; line-height: 1.5; }
    .cooking-card .cooking-logo { height: 52px; width: auto; display: block; margin-bottom: 12px; border-radius: 8px; }

    .music-section iframe { border-radius: 12px; max-width: 420px; width: 100%; margin-top: 4px; }

    /* ---- Snapshots gallery ---- */
    .gallery-strip {
      display: flex; gap: 10px; overflow-x: auto; padding-bottom: 10px;
      scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;
      scrollbar-width: thin; scrollbar-color: var(--line) transparent;
    }
    .gallery-strip::-webkit-scrollbar { height: 7px; }
    .gallery-strip::-webkit-scrollbar-thumb { background: var(--line); border-radius: 999px; }
    .gthumb {
      flex: 0 0 auto; height: 150px; border-radius: 12px; overflow: hidden;
      border: 1px solid var(--line); cursor: pointer; scroll-snap-align: start;
      background: var(--card); transition: transform 0.18s, border-color 0.18s, box-shadow 0.18s;
    }
    .gthumb img { height: 100%; width: auto; display: block; object-fit: cover; }
    .gthumb:hover { transform: translateY(-3px); border-color: var(--accent); box-shadow: 0 10px 24px rgba(26,20,16,0.16); }

    .lightbox {
      position: fixed; inset: 0; z-index: 50; display: none;
      align-items: center; justify-content: center; padding: 24px;
      background: rgba(26,20,16,0.82); backdrop-filter: blur(3px); cursor: zoom-out;
    }
    .lightbox.open { display: flex; }
    .lightbox img { max-width: 100%; max-height: 100%; border-radius: 12px; box-shadow: 0 20px 60px rgba(0,0,0,0.5); }
    .lightbox .lb-close {
      position: absolute; top: 18px; right: 22px; font-size: 1.6rem; line-height: 1;
      color: #f8e4c9; background: none; border: none; cursor: pointer; opacity: 0.85;
    }
    .lightbox .lb-close:hover { opacity: 1; }
    .lightbox .lb-nav {
      position: absolute; top: 50%; transform: translateY(-50%);
      font-size: 2.6rem; line-height: 1; color: #f8e4c9; background: none; border: none;
      cursor: pointer; opacity: 0.7; padding: 10px 16px; transition: opacity 0.18s; user-select: none;
    }
    .lightbox .lb-nav:hover { opacity: 1; }
    .lightbox .lb-prev { left: 6px; }
    .lightbox .lb-next { right: 6px; }

    @media (max-width: 560px) {
      body { padding: 48px 18px 72px; }
      .stats { grid-template-columns: repeat(2, 1fr); }
      .cards { grid-template-columns: 1fr; }
      h1 { font-size: 1.7rem; }
      .header { gap: 16px; }
      .profile-photo { width: 68px; height: 68px; min-width: 68px; }
    }
  </style>
</head>
<body>
  <div class="container">

    <div class="header">
      <img src="/profile.jpg" alt="Julian Fife" class="profile-photo">
      <div>
        <h1>Julian John Fife</h1>
        <p class="tagline">Writer, cook, and web builder in Austin, TX</p>
      </div>
    </div>
    <div class="tagline-chips">
      <span class="chip">writer</span>
      <span class="chip">cook</span>
      <span class="chip">web builder</span>
    </div>

    <!-- Stats strip (live, baked at build) -->
    <div class="stats">
      <a class="stat" href="/concert-log" title="Live events log">
        <span class="num">{stats.events}</span><span class="lbl">Live events</span>
      </a>
      <a class="stat" href="/concert-log" title="Live events log">
        <span class="num">{stats.venues}</span><span class="lbl">Venues</span>
      </a>
      <a class="stat" href="/travel-log" title="Travel log">
        <span class="num">{stats.trips}</span><span class="lbl">Trips</span>
      </a>
      <a class="stat" href="/travel-log" title="Travel log">
        <span class="num">{stats.countries}</span><span class="lbl">Countries</span>
      </a>
    </div>

    <div class="section">
      <p class="section-label">Bio</p>
      <ul class="list">
        <li><span class="lead">Currently live in Austin, TX, with my wife, <span class="hover-pic">Amani<span class="hover-tooltip"><img src="/amani.jpeg" alt="Amani"></span></span>, and our two cats, <span class="hover-pic">Teddy<span class="hover-tooltip"><img src="/teddy.jpeg" alt="Teddy"></span></span> &amp; <span class="hover-pic">Bear<span class="hover-tooltip"><img src="/bear.jpeg" alt="Bear"></span></span></span></li>
        <li><span class="lead">Born &amp; raised in Denver, CO <img src="/co_flag.svg.png" alt="Colorado flag" class="inline-flag"></span></li>
        <li><span class="lead">BA, Economics &mdash; UT Austin | MBA &mdash; UT Austin <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/8/8d/Texas_Longhorns_logo.svg/120px-Texas_Longhorns_logo.svg.png" alt="Longhorns logo" class="longhorns-logo"></span></li>
        <li><span class="lead">Love to cook, travel, build web tools, and go to football games <img src="https://upload.wikimedia.org/wikipedia/en/thumb/4/44/Denver_Broncos_logo.svg/120px-Denver_Broncos_logo.svg.png" alt="Broncos logo" class="longhorns-logo"></span></li>
      </ul>
    </div>

    <div class="section">
      <p class="section-label">Writing</p>
      <ul class="list">
        {posts.map(p => (
          <li><span class="year">{p.year}</span><a href={p.url} target="_blank" rel="noopener noreferrer">{p.title}</a></li>
        ))}
      </ul>
      <a href="https://julianfife.substack.com/" target="_blank" rel="noopener noreferrer" class="subscribe-link"><img src="/substack.png" alt="">subscribe on substack &rarr;</a>
    </div>

    <div class="section">
      <p class="section-label">Favorite Austin Restaurants</p>
      <ul class="list restaurant-list">
        <li><a href="https://www.barleyswine.com/" target="_blank" rel="noopener noreferrer">Barley Swine</a></li>
        <li><a href="https://sushibarhospitality.com/locations/austin/" target="_blank" rel="noopener noreferrer">Sushi | Bar</a></li>
        <li><a href="https://leroyandlewisbbq.com/" target="_blank" rel="noopener noreferrer">Leroy &amp; Lewis Barbecue</a></li>
        <li><a href="https://www.oddduckaustin.com/" target="_blank" rel="noopener noreferrer">Odd Duck</a></li>
        <li><a href="https://www.fndaustin.com/" target="_blank" rel="noopener noreferrer">Foreign &amp; Domestic</a></li>
        <li><a href="https://beliapp.co/app/julianfife" target="_blank" rel="noopener noreferrer">see more</a></li>
      </ul>
    </div>

    <div class="section">
      <p class="section-label">Cooking</p>
      <div class="cards">
        <a href="https://fifespice.com" target="_blank" rel="noopener noreferrer" class="big-link cooking-card">
          <img class="cooking-logo" src="/fife-spice-logo.png" alt="Fife Spice" loading="lazy">
          <span class="title">Fife Spice <span class="arrow">&rarr;</span></span>
          <span class="sub">My cooking site &mdash; recipes, technique &amp; what I'm making</span>
        </a>
        <a href="https://recipeats.julianfife.com" target="_blank" rel="noopener noreferrer" class="big-link">
          <span class="title">Recipes <span class="arrow">&rarr;</span></span>
          <span class="sub">A running list of everything I cook</span>
        </a>
      </div>
    </div>

    <div class="section">
      <p class="section-label">Connect</p>
      <div class="social-group">
        <p class="social-group-label">personal</p>
        <div class="social-icons">
          <a href="https://x.com/julianfife" target="_blank" rel="noopener noreferrer" title="X / Twitter">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://instagram.com/julianfife" target="_blank" rel="noopener noreferrer" title="Instagram @julianfife">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.linkedin.com/in/julian-fife/" target="_blank" rel="noopener noreferrer" title="LinkedIn">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
        </div>
      </div>
      <div class="social-group">
        <p class="social-group-label">cooking</p>
        <div class="social-icons">
          <a href="https://instagram.com/fifespice" target="_blank" rel="noopener noreferrer" title="Instagram @fifespice">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.tiktok.com/@fifespice?_r=1&_t=ZP-94FtxJplqJT" target="_blank" rel="noopener noreferrer" title="TikTok @fifespice">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
