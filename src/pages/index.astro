    <div class="section">
      <p class="section-label">Logs</p>
      <div class="cards">
        <a href="/concert-log" target="_blank" rel="noopener noreferrer" class="big-link">
          <span class="title">Live Events <span class="arrow">&rarr;</span></span>
          <span class="sub">Every concert, stand-up &amp; football game I've been to &middot; timeline, map &amp; stats</span>
        </a>
        <a href="/travel-log" target="_blank" rel="noopener noreferrer" class="big-link">
          <span class="title">Travel <span class="arrow">&rarr;</span></span>
          <span class="sub">Every place I've traveled to &middot; map, timeline &amp; stats</span>
        </a>
      </div>
    </div>

    {tripPhotos.length > 0 && (
      <div class="section">
        <p class="section-label">Snapshots</p>
        <div class="gallery-strip">
          {tripPhotos.map(src => (
            <button class="gthumb" data-full={src} aria-label="View photo">
              <img src={src} alt="" loading="lazy" />
            </button>
          ))}
        </div>
      </div>
    )}

    <div class="section music-section">
      <p class="section-label">Currently Listening To</p>
      <iframe allow="autoplay *; encrypted-media *; fullscreen *; clipboard-write"
        frameborder="0"
        height="175"
        sandbox="allow-forms allow-popups allow-same-origin allow-scripts allow-storage-access-by-user-activation allow-top-navigation-by-user-activation"
        src="https://embed.music.apple.com/us/album/million-colors/1888209821?i=1888209822">
      </iframe>
    </div>

  </div>

  {tripPhotos.length > 0 && (
    <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
      <button class="lb-close" id="lbClose" aria-label="Close">&times;</button>
      <button class="lb-nav lb-prev" id="lbPrev" aria-label="Previous photo">&lsaquo;</button>
      <img id="lbImg" src="" alt="" />
      <button class="lb-nav lb-next" id="lbNext" aria-label="Next photo">&rsaquo;</button>
    </div>
  )}

  <script>
    const lb = document.getElementById("lightbox");
    const lbImg = document.getElementById("lbImg");
    if (lb && lbImg) {
      const thumbs = [...document.querySelectorAll(".gthumb")];
      const srcs = thumbs.map((t) => t.getAttribute("data-full"));
      let idx = 0;
      const show = (i) => { idx = (i + srcs.length) % srcs.length; lbImg.setAttribute("src", srcs[idx]); }; // wrap-around
      const open = (i) => { show(i); lb.classList.add("open"); };
      const close = () => { lb.classList.remove("open"); lbImg.setAttribute("src", ""); };
      thumbs.forEach((btn, i) => btn.addEventListener("click", () => open(i)));

      const prev = document.getElementById("lbPrev");
      const next = document.getElementById("lbNext");
      prev && prev.addEventListener("click", (e) => { e.stopPropagation(); show(idx - 1); });
      next && next.addEventListener("click", (e) => { e.stopPropagation(); show(idx + 1); });

      // Click the backdrop (not the image or arrows) to close.
      lb.addEventListener("click", (e) => { if (e.target === lbImg || e.target.closest(".lb-nav")) return; close(); });
      document.addEventListener("keydown", (e) => {
        if (!lb.classList.contains("open")) return;
        if (e.key === "Escape") close();
        else if (e.key === "ArrowRight") show(idx + 1);
        else if (e.key === "ArrowLeft") show(idx - 1);
      });
    }
  </script>
</body>
