---
// Homepage — "refined warm" redesign. Keeps the cream + monospace identity,
// adds a live stats strip and an auto-updating Substack writing feed, both
// fetched at BUILD time (no client JS, no load-flash, no CORS issues).
//
// All network calls are wrapped with a timeout + fallback so a flaky sheet or
// feed can never break or hang the build (important in CI).

const CONCERT_CSV = "https://docs.google.com/spreadsheets/d/e/2PACX-1vSgzsdhJH86SZb6YnQc3SFagzx5sCp0tPu53w4OtfIhU-8fkrOuCjKcJVhVnlFl4oY-M5RbQniM9D_B/pub?output=csv";
const TRAVEL_CSV  = "https://docs.google.com/spreadsheets/d/e/2PACX-1vTaYaD031CsA8keUhvPWwot0J07gbJ6PIseiehSiODGdHP1l6ZeoeKa9V-V_ExuLo--06gNnMsmfb7T/pub?output=csv";
const SUBSTACK_RSS = "https://julianfife.substack.com/feed";

async function fetchText(url, ms = 10000) {
  const ctrl = new AbortController();
  const t = setTimeout(() => ctrl.abort(), ms);
  try {
    const res = await fetch(url, { signal: ctrl.signal });
    return res.ok ? await res.text() : null;
  } catch { return null; } finally { clearTimeout(t); }
}

// Minimal CSV parser (handles quoted fields, embedded commas/newlines).
function parseCSV(text) {
  const rows = []; let row = [], f = "", q = false;
  text = text.replace(/\r\n?/g, "\n");
  for (let i = 0; i < text.length; i++) {
    const c = text[i];
    if (q) {
      if (c === '"') { if (text[i + 1] === '"') { f += '"'; i++; } else q = false; }
      else f += c;
    } else if (c === '"') q = true;
    else if (c === ",") { row.push(f); f = ""; }
    else if (c === "\n") { row.push(f); rows.push(row); row = []; f = ""; }
    else f += c;
  }
  if (f.length || row.length) { row.push(f); rows.push(row); }
  return rows;
}
function toObjects(text) {
  const rows = parseCSV(text).filter(r => r.some(c => c.trim()));
  if (!rows.length) return [];
  const head = rows[0].map(h => h.trim());
  return rows.slice(1).map(r => Object.fromEntries(head.map((h, i) => [h, (r[i] || "").trim()])));
}

// ---- Stats (build-time, with sensible fallbacks if a sheet is unreachable) ----
let stats = { events: 147, venues: 42, trips: 32, countries: 5 };

// Mirror the travel log's own slugify so "Trips" grouping matches it exactly.
const slugify = (s) => (s || "").toLowerCase().replace(/['']/g, "").replace(/[^a-z0-9]+/g, "-").replace(/^-+|-+$/g, "");
const concertText = await fetchText(CONCERT_CSV);
const travelText = await fetchText(TRAVEL_CSV);
if (concertText) {
  const c = toObjects(concertText).filter(r => r.date);
  if (c.length) {
    stats.events = c.length;
    stats.venues = new Set(c.map(r => r.venue).filter(Boolean)).size;
  }
}
if (travelText) {
  // Match the travel log: valid rows are those with a date_start, and "Trips"
  // groups rows sharing a trip_id (solo rows keyed by date_start + place), so a
  // multi-stop trip counts once — same as tripGroups()/rowsToTrips() there.
  // Raw row count is the log's "Destinations", NOT its "Trips".
  const t = toObjects(travelText).filter(r => r.date_start);
  if (t.length) {
    const tripKeys = new Set(t.map(r => r.trip_id ? "id:" + r.trip_id : "solo:" + r.date_start + ":" + slugify(r.place)));
    stats.trips = tripKeys.size;
    stats.countries = new Set(t.map(r => r.country).filter(Boolean)).size;
  }
}

// ---- Writing feed (build-time Substack RSS, falls back to hand-listed posts) ----
function decode(s) {
  return s.replace(/<!\[CDATA\[([\s\S]*?)\]\]>/g, "$1")
          .replace(/&amp;/g, "&").replace(/&lt;/g, "<").replace(/&gt;/g, ">")
          .replace(/&#39;|&apos;/g, "'").replace(/&quot;/g, '"').trim();
}
let posts = [
  { title: "Tanner", url: "https://julianfife.substack.com/p/tanner", year: "2026" },
  { title: "James Talarico Is Texas", url: "https://julianfife.substack.com/p/james-talarico-is-texas", year: "2026" },
];
const rss = await fetchText(SUBSTACK_RSS);
if (rss) {
  const items = [...rss.matchAll(/<item>([\s\S]*?)<\/item>/g)].map(m => m[1]);
  const parsed = items.map(it => {
    const title = (it.match(/<title>([\s\S]*?)<\/title>/) || [])[1];
    const link = (it.match(/<link>([\s\S]*?)<\/link>/) || [])[1];
    const date = (it.match(/<pubDate>([\s\S]*?)<\/pubDate>/) || [])[1] || "";
    const year = (date.match(/\b(20\d{2})\b/) || [])[1] || "";
    return title && link ? { title: decode(title), url: decode(link), year } : null;
  }).filter(Boolean);
  if (parsed.length) posts = parsed.slice(0, 4);
}

// ---- Trip snapshots: every image dropped directly into public/trips/ ----
// Read at build time, so adding a photo to the folder makes it appear on the
// next build — no list to maintain here. (Per-trip galleries in the travel log
// are driven separately by the sheet's photo_folder/photos columns.)
import { readdirSync } from "node:fs";
import { fileURLToPath } from "node:url";
let tripPhotos = [];
try {
  const dir = fileURLToPath(new URL("../../public/trips", import.meta.url));
  tripPhotos = readdirSync(dir)
    .filter(f => /\.(jpe?g|png|webp)$/i.test(f))
    .sort()
    .map(f => "/trips/" + f);
} catch { /* folder missing — gallery just won't render */ }
